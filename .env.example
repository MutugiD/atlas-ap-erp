DATABASE_URL=postgres://atlas_owner:atlas_owner@localhost:5432/atlas_ap
APP_DATABASE_ROLE=app_user
AWS_REGION=us-east-1
AWS_PROFILE=default
S3_INVOICE_BUCKET=atlas-ap-documents-dev
BEDROCK_SUPERVISOR_AGENT_ID=
BEDROCK_AGENTCORE_RUNTIME_ARN=
AGENT_PROVIDER=local
# Ollama / llama.cpp tiered LLM agent provider (used when AGENT_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_API_STYLE=ollama                             # ollama (/api/chat) | openai (/v1/chat/completions, llama.cpp)
OLLAMA_API_KEY=
OLLAMA_MODEL_COMPLEX=glm-5.2:cloud                  # extract (orchestrator)
OLLAMA_MODEL_STANDARD=glm-5.1:cloud                 # GL coding
OLLAMA_MODEL_SIMPLE=gemini-3-flash-preview:latest   # approval routing (glm-5.0 not available on Ollama cloud)
OLLAMA_LLM_TASKS=extract,code,route                 # tasks on the LLM; validate/match stay deterministic
OLLAMA_MODEL=                                       # legacy single-model fallback for any unset tier
# Bank connector (used when BANK_PROVIDER=jenga). Endpoints/token flow confirmed at onboarding.
BANK_PROVIDER=manual
JENGA_BASE_URL=https://api.finserve.africa
JENGA_ACCESS_TOKEN=
JENGA_PRIVATE_KEY=


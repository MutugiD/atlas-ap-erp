{
  "name": "atlas-ap-erp",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*",
    "infra"
  ],
  "scripts": {
    "dev:api": "bun --filter @atlas/api dev",
    "dev:web": "bun --filter @atlas/web dev",
    "dev:support": "bun --filter @atlas/support-agent dev",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "infra:synth": "bun --filter @atlas/infra synth",
    "db:generate": "drizzle-kit generate --config packages/db/drizzle.config.ts",
    "license:audit": "bun run scripts/license-audit.ts"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-agent-runtime": "^3.699.0",
    "@aws-sdk/client-s3": "^3.699.0",
    "@aws-sdk/client-secrets-manager": "^3.699.0",
    "@aws-sdk/s3-request-presigner": "^3.699.0",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "aws-cdk-lib": "^2.171.1",
    "bullmq": "^5.31.0",
    "constructs": "^10.4.2",
    "cockatiel": "^3.2.1",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.2.1",
    "hono": "^4.6.12",
    "ioredis": "^5.4.2",
    "next": "^15.0.4",
    "prom-client": "^15.1.3",
    "jose": "^5.9.6",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.147",
    "@types/bun": "^1.1.14",
    "@types/node": "^20.17.6",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "aws-cdk": "^2.171.1",
    "drizzle-kit": "^0.27.1",
    "typescript": "^5.7.2"
  }
}
